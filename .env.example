# Copy to $SCRATCH/kara/.env on Helios and fill in values.
# Never commit .env to git.
#
#   cp .env.example $SCRATCH/kara/.env
#   nano $SCRATCH/kara/.env

# HuggingFace token — required only if you want to download gated/private models.
# Aya-Expanse-8B is openly licensed, so HF_TOKEN is technically optional,
# but recommended to avoid rate limits.
HF_TOKEN=hf_your_token_here

# (Optional) Weights & Biases for experiment tracking
# WANDB_API_KEY=your_key_here
# WANDB_ENTITY=your_team_or_username
# WANDB_PROJECT=kara
