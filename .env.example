# Copy to $SCRATCH/kara/.env on Helios and fill in values.
# Never commit .env to git.
#
#   cp .env.example $SCRATCH/kara/.env
#   nano $SCRATCH/kara/.env

# HuggingFace token — REQUIRED for the LLM jobs.
# Aya-Expanse-8B is a GATED Cohere model. To use it you must:
#   1. Sign in at https://huggingface.co
#   2. Accept the license at https://huggingface.co/CohereForAI/aya-expanse-8b
#   3. Create a token at https://huggingface.co/settings/tokens
#      (read-only scope is enough)
#   4. Paste it below
HF_TOKEN=hf_your_token_here

# (Optional) Weights & Biases for experiment tracking
# WANDB_API_KEY=your_key_here
# WANDB_ENTITY=your_team_or_username
# WANDB_PROJECT=kara
